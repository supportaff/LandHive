# ============================================================================
# LandHive Environment Variables
# Copy this to .env.local and fill in your actual values
# ============================================================================

# ─── Supabase (PostgreSQL Database) ──────────────────────────────────────────
NEXT_PUBLIC_LH_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
LH_SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
LH_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Clerk (Authentication) ───────────────────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxx

# ─── PayU Payment Gateway ─────────────────────────────────────────────────────
LH_PAYU_KEY=your_merchant_key
LH_PAYU_SALT=your_merchant_salt
LH_PAYU_ENV=false  # false = test mode | true = live production mode

# ─── Google Maps & Places API ─────────────────────────────────────────────────
VITE_GOOGLE_MAPS_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxx

# ─── Resend (Transactional Emails) ───────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxx

# ─── App Config ───────────────────────────────────────────────────────────────
APP_URL=https://landhive.in
