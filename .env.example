# ─── LandHive Environment Variables ─────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
#
# For Vercel deployment: add these in
# Dashboard → Project → Settings → Environment Variables


# ─── Supabase PostgreSQL ─────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → Project Settings → API
# ⚠️  Used by ALL api/* serverless functions + React components

# Project URL (public)
NEXT_PUBLIC_LH_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co

# Anon/Public key (safe to expose in browser — respects RLS)
LH_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.ey....

# Service Role key (SERVER-SIDE ONLY — bypasses RLS, never expose to browser)
LH_SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.ey....

# JWT Secret (for custom auth verification if needed)
LH_SUPABASE_JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

# Direct Postgres connection strings (for migrations, admin tools, Prisma)
LH_POSTGRES_URL=postgresql://postgres.xxxxx:password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
LH_POSTGRES_PRISMA_URL=postgresql://postgres.xxxxx:password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
LH_POSTGRES_URL_NON_POOLING=postgresql://postgres.xxxxx:password@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# Parsed components (optional — for direct pg client usage)
LH_POSTGRES_USER=postgres.xxxxxxxxxxxxx
LH_POSTGRES_HOST=aws-0-ap-south-1.pooler.supabase.com
LH_POSTGRES_PASSWORD=your-database-password
LH_POSTGRES_DATABASE=postgres


# ─── Clerk Authentication ────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ─── PayU Payment Gateway ────────────────────────────────────────────────────
# Get from: https://dashboard.payu.in → API Keys
# Set LH_PAYU_ENV=false for test mode, true for production
LH_PAYU_KEY=your_payu_merchant_key
LH_PAYU_SALT=your_payu_salt_v2
LH_PAYU_ENV=false


# ─── Resend Email ────────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
# Verify your domain first (e.g. landhive.in) in Resend dashboard
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=hello@landhive.in
ADMIN_EMAIL=admin@landhive.in


# ─── App Config ──────────────────────────────────────────────────────────────
# No trailing slash
APP_URL=https://landhive.in
# For local dev: APP_URL=http://localhost:5173


# ─── Google Maps ─────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Maps JavaScript API + Geocoding API
VITE_GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
