# ─── LandHive Environment Variables ─────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
#
# For Vercel deployment: add these in
# Dashboard → Project → Settings → Environment Variables


# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# Get from: https://cloud.mongodb.com → Connect → Drivers → Node.js
# ⚠️  Used by ALL api/* serverless functions
LH_MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority


# ─── Clerk Authentication ─────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ─── PayU Payment Gateway ─────────────────────────────────────────────────────
# Get from: https://dashboard.payu.in → API Keys
# Set LH_PAYU_ENV=false for test mode, true for production
LH_PAYU_KEY=your_payu_merchant_key
LH_PAYU_SALT=your_payu_salt_v2
LH_PAYU_ENV=false


# ─── Resend Email ─────────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
# Verify your domain first (e.g. landhive.in) in Resend dashboard
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=hello@landhive.in
ADMIN_EMAIL=admin@landhive.in


# ─── App Config ───────────────────────────────────────────────────────────────
# No trailing slash
APP_URL=https://landhive.in
# For local dev: APP_URL=http://localhost:5173


# ─── Google Maps ──────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Maps JavaScript API + Geocoding API
VITE_GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
