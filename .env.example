# LandHive Environment Variables
# Copy this file to .env and fill in your values

# Google Maps API
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Clerk Auth (Vite uses VITE_ prefix for frontend vars)
# Value comes from NEXT_PUBLIC_LH_CLERK_PUBLISHABLE_KEY in Vercel Clerk integration
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx

# Clerk Secret Key (server-side / API routes only)
# Value comes from LH_CLERK_SECRET_KEY in Vercel Clerk integration
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxx

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/landhive?retryWrites=true&w=majority

# Resend (Email)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=hello@landhive.in

# PayU Payment Gateway (server-side only)
PAYU_KEY=your_payu_merchant_key
PAYU_SALT=your_payu_merchant_salt
# "live" → https://secure.payu.in/_payment  |  anything else → test endpoint
PAYU_ENV=live

# Cloudinary (photo uploads)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# App URL
VITE_APP_URL=https://landhive.in
